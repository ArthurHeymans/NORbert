// Tang Primer 25K Dock Constraints File for SPI Flash Emulator
// Board: Sipeed Tang Primer 25K + Dock ext-board
// FPGA: Gowin GW5A-LV25MG121NC1/I0
//
// SDRAM pin mappings from NESTang-25K and LicheeTang25k_SDRAM references
// (both agree on all SDRAM pin assignments)
//
// The SDRAM module has TWO MT48LC16M16A2 chips with a SINGLE CS pin (K9).
// The module PCB has an onboard inverter: CS=LOW selects chip 0,
// CS=HIGH selects chip 1.

// ============================================================
// Clock Input (50MHz crystal oscillator)
// ============================================================
IO_LOC "clk_50mhz" E2;
IO_PORT "clk_50mhz" IO_TYPE=LVCMOS33 PULL_MODE=NONE;

// ============================================================
// User LED (active low, on core board)
// ============================================================
IO_LOC "led" E8;
IO_PORT "led" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;

// ============================================================
// User Buttons (on core board) -- H11/H10 no longer used
// ============================================================

// ============================================================
// UART via FTDI debugger on dock
// ============================================================
IO_LOC "uart_tx" C3;
IO_LOC "uart_rx" B3;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// ============================================================
// PMOD 1 -- SPI Flash Emulation Interface (all 8 signals)
//
//   Top row:    G11  D11  B11  C11  GND  3V3
//   Bottom row: G10  D10  B10  C10  GND  3V3
// ============================================================

// --- PMOD 1 top row: SPI core signals ---

// SPI Chip Select (active low)
IO_LOC "spi_cs_pin" G11;
IO_PORT "spi_cs_pin" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// SPI Clock (pull-down prevents floating noise when no SPI master connected)
IO_LOC "spi_clk_pin" D11;
IO_PORT "spi_clk_pin" IO_TYPE=LVCMOS33 PULL_MODE=DOWN;

// SPI IO0 (MOSI / bidirectional in dual/quad mode)
IO_LOC "spi_mosi_pin" B11;
IO_PORT "spi_mosi_pin" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;

// SPI IO1 (MISO / bidirectional in dual/quad mode)
IO_LOC "spi_miso_pin" C11;
IO_PORT "spi_miso_pin" IO_TYPE=LVCMOS33 DRIVE=8;

// --- PMOD 1 bottom row: SPI extended + aux ---

// SPI IO2 (/WP / bidirectional in quad mode)
IO_LOC "spi_io2_pin" G10;
IO_PORT "spi_io2_pin" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;

// SPI IO3 (/HOLD / bidirectional in quad mode)
IO_LOC "spi_io3_pin" D10;
IO_PORT "spi_io3_pin" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;

// SPI Power Detection (active high when SPI master is powered)
IO_LOC "spi_power_pin" B10;
IO_PORT "spi_power_pin" IO_TYPE=LVCMOS33 PULL_MODE=DOWN;

// Debug output
IO_LOC "spi_debug_pin" C10;
IO_PORT "spi_debug_pin" IO_TYPE=LVCMOS33 DRIVE=8;

// ============================================================
// PMOD 2 -- FT245 control signals (top row) + 4 spare (bottom)
//
// FT2232H Channel A in async 245 FIFO mode.
// FT2232H EEPROM must be configured for "245 FIFO" on Channel A
// (one-time setup via FT_PROG).
//
//   Top row:    A11  E11  K11  L5   GND  3V3
//   Bottom row: A10  E10  L11  K5   GND  3V3
// ============================================================

// --- PMOD 2 top row: FT245 control ---

// FT245 RXF# -- data available (active low, output from FT2232H)
IO_LOC "ft_rxf_n" A11;
IO_PORT "ft_rxf_n" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// FT245 TXE# -- transmit buffer not full (active low, output from FT2232H)
IO_LOC "ft_txe_n" E11;
IO_PORT "ft_txe_n" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// FT245 RD# -- read strobe (active low, output from FPGA)
IO_LOC "ft_rd_n" K11;
IO_PORT "ft_rd_n" IO_TYPE=LVCMOS33 DRIVE=8;

// FT245 WR# -- write strobe (active low, output from FPGA)
IO_LOC "ft_wr_n" L5;
IO_PORT "ft_wr_n" IO_TYPE=LVCMOS33 DRIVE=8;

// --- PMOD 2 bottom row: spare ---
// (spare) A10
// (spare) E10
// (spare) L11
// (spare) K5

// ============================================================
// PMOD 3 -- FT245 data bus D[7:0]
//
//   Top row:    F5   G7   H8   H5   GND  3V3
//   Bottom row: G5   G8   H7   J5   GND  3V3
// ============================================================

// --- PMOD 3 top row: FT245 data[3:0] ---

IO_LOC "ft_data[3]" F5;
IO_LOC "ft_data[2]" G7;
IO_LOC "ft_data[1]" H8;
IO_LOC "ft_data[0]" H5;
IO_PORT "ft_data[0]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "ft_data[1]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "ft_data[2]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "ft_data[3]" IO_TYPE=LVCMOS33 DRIVE=8;

// --- PMOD 3 bottom row: FT245 data[7:4] ---

IO_LOC "ft_data[6]" G5;
IO_LOC "ft_data[5]" G8;
IO_LOC "ft_data[4]" H7;
IO_LOC "ft_data[7]" J5;
IO_PORT "ft_data[4]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "ft_data[5]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "ft_data[6]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "ft_data[7]" IO_TYPE=LVCMOS33 DRIVE=8;

// ============================================================
// External SDRAM Module (via 40-pin connector on dock)
// Two MT48LC16M16A2 chips (32MB each = 64MB total)
// 16-bit shared data bus, single CS with onboard inverter
//
// Pin assignments verified from both NESTang-25K and LicheeTang25k_SDRAM
// Note: No CKE pin - tied high on module PCB
// ============================================================

// SDRAM Clock (routed through IODELAY in top.v for phase adjustment)
IO_LOC "O_sdram_clk" E3;
IO_PORT "O_sdram_clk" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Chip Select (single pin - module has onboard inverter for 2nd chip)
// LOW = chip 0, HIGH = chip 1
IO_LOC "O_sdram_cs_n" K9;
IO_PORT "O_sdram_cs_n" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Row/Column Address Strobe
IO_LOC "O_sdram_ras_n" L10;
IO_PORT "O_sdram_ras_n" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_cas_n" K10;
IO_PORT "O_sdram_cas_n" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Write Enable
IO_LOC "O_sdram_wen_n" J7;
IO_PORT "O_sdram_wen_n" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Address (13-bit for MT48LC16M16A2: 8192 rows, 9-bit column, 4 banks)
IO_LOC "O_sdram_addr[0]" F6;
IO_PORT "O_sdram_addr[0]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[1]" F7;
IO_PORT "O_sdram_addr[1]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[2]" J10;
IO_PORT "O_sdram_addr[2]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[3]" J11;
IO_PORT "O_sdram_addr[3]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[4]" K7;
IO_PORT "O_sdram_addr[4]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[5]" H2;
IO_PORT "O_sdram_addr[5]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[6]" H1;
IO_PORT "O_sdram_addr[6]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[7]" H4;
IO_PORT "O_sdram_addr[7]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[8]" G4;
IO_PORT "O_sdram_addr[8]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[9]" J2;
IO_PORT "O_sdram_addr[9]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[10]" J8;
IO_PORT "O_sdram_addr[10]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[11]" J1;
IO_PORT "O_sdram_addr[11]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_addr[12]" D1;
IO_PORT "O_sdram_addr[12]" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Bank Address
IO_LOC "O_sdram_ba[0]" L9;
IO_PORT "O_sdram_ba[0]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_ba[1]" K8;
IO_PORT "O_sdram_ba[1]" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Data Mask (2-bit for 16-bit bus)
IO_LOC "O_sdram_dqm[0]" L8;
IO_PORT "O_sdram_dqm[0]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "O_sdram_dqm[1]" L7;
IO_PORT "O_sdram_dqm[1]" IO_TYPE=LVCMOS33 DRIVE=16;

// SDRAM Data Bus (16-bit shared between both chips)
IO_LOC "IO_sdram_dq[0]" K2;
IO_PORT "IO_sdram_dq[0]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[1]" K1;
IO_PORT "IO_sdram_dq[1]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[2]" L1;
IO_PORT "IO_sdram_dq[2]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[3]" L2;
IO_PORT "IO_sdram_dq[3]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[4]" K4;
IO_PORT "IO_sdram_dq[4]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[5]" J4;
IO_PORT "IO_sdram_dq[5]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[6]" G1;
IO_PORT "IO_sdram_dq[6]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[7]" G2;
IO_PORT "IO_sdram_dq[7]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[8]" E1;
IO_PORT "IO_sdram_dq[8]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[9]" A1;
IO_PORT "IO_sdram_dq[9]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[10]" F2;
IO_PORT "IO_sdram_dq[10]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[11]" F1;
IO_PORT "IO_sdram_dq[11]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[12]" B2;
IO_PORT "IO_sdram_dq[12]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[13]" C2;
IO_PORT "IO_sdram_dq[13]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[14]" L4;
IO_PORT "IO_sdram_dq[14]" IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC "IO_sdram_dq[15]" L3;
IO_PORT "IO_sdram_dq[15]" IO_TYPE=LVCMOS33 DRIVE=16;
